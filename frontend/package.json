{
  "name": "webapp-portfolio",
  "version": "2.0.3",
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "make clean",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "pre-release": "npm run test",
    "test:nuxt": "vitest run tests/nuxt",
    "test:sass": "vitest run tests/sass",
    "dev": "tinacms dev -c \"nuxt dev\"",
    "build": "tinacms build && nuxt build",
    "serve": "npm run build && nuxt preview",
    "test:semantic": "vitest run tests/semantic",
    "test": "vitest run && npm run test:nuxt && npm run test:sass",
    "deploy": "npm run test && npm run build && npm run generate && netlify deploy --dir=.output/public --no-build --prod --message='Se_CHANGELOG.md_for_forbedringer_og_endringer'"
  },
  "dependencies": {
    "@nuxt/content": "^3.14.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/google-gtag": "^1.0.4",
    "better-sqlite3": "^12.10.0",
    "bootstrap-icons": "^1.13.1",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.1.0",
    "lumina-sass": "^3.2.6",
    "nuxt": "^4.4.2",
    "nuxt-gtag": "^4.1.0",
    "tinacms": "^3.6.3",
    "typescript": "^5.9.3",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/sitemap": "^8.0.15",
    "@pinia/nuxt": "^0.11.3",
    "@tinacms/cli": "^2.3.1",
    "@types/node": "^25.5.0",
    "@vue/test-utils": "^2.4.11",
    "bootstrap-icons": "^1.13.1",
    "jsdom": "^29.1.1",
    "netlify-cli": "^26.1.0",
    "patch-package": "^8.0.1",
    "pinia": "^3.0.4",
    "postinstall-postinstall": "^2.1.0",
    "sass": "^1.100.0",
    "sass-true": "^10.1.0",
    "vitest": "^4.1.8"
  }
}
