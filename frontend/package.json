    "better-sqlite3": "^12.8.0",
    "bootstrap-icons": "^1.13.1",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.1.0",
    "nuxt": "^4.4.2",
    "nuxt-gtag": "^4.1.0",
    "tinacms": "^3.6.3",
    "typescript": "^5.9.3",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@nuxtjs/sitemap": "^8.0.1",
